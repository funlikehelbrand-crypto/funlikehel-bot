# ===== FUN like HEL — api.env =====
# Skopiuj ten plik jako "api.env" i uzupełnij wartości

# Meta / Instagram
VERIFY_TOKEN=dowolny_tajny_token_do_weryfikacji_webhooka
META_APP_SECRET=sekret_aplikacji_z_meta_developer_portal
PAGE_ACCESS_TOKEN=token_dostepu_do_strony_facebook

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT)
OPENAI_API_KEY=sk-proj-...

# Google Gemini
GEMINI_API_KEY=AIza...

# Serwer
PORT=8000

# TikTok
TT_CLIENT_KEY=twoj-client-key
TT_CLIENT_SECRET=twoj-client-secret

# Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN=tu-wklej-token

# SerwerSMS.pl
SERWERSMS_LOGIN=webapi_funlikehel
SERWERSMS_PASSWORD=tu-wklej-haslo
SERWERSMS_TOKEN=tu-wklej-token
SERWERSMS_SENDER=FUNlikeHEL

# WhatsApp Cloud API
WHATSAPP_TOKEN=tu-wklej-system-user-access-token
WHATSAPP_PHONE_NUMBER_ID=tu-wklej-phone-number-id

# Facebook Groups
FB_USER_ACCESS_TOKEN=tu-wklej-user-access-token
FB_GROUP_IDS=id-grupy-1,id-grupy-2
FB_PAGE_ID=tu-wklej-id-profilu-bota

# WordPress REST API (Application Password — do aktywacji pluginów)
WP_APP_PASSWORD=tu-wklej-application-password-z-wordpress

# Instagram multi-konto — dodatkowe konta IG (główne = PAGE_ACCESS_TOKEN)
Insta_surf4hel=tu-wklej-token-dla-surf4hel
# Insta_trzecie_konto=tu-wklej-token

# DM Campaign (automatyczne zaproszenia /ekipa przez Instagram DM)
DM_CAMPAIGN_ENABLED=0
DM_CAMPAIGN_DELAY=120
DM_CAMPAIGN_MESSAGE=

# Auto-odpowiedzi DM — które konta IG mają odpowiadać na wiadomości (lista po przecinku)
DM_RESPONSE_ACCOUNTS=funlikehel
